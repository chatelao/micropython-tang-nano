# tang_nano_4k.resc

using sysbus
mach create "tang_nano_4k"

$repl?=@test/tang_nano_4k.repl
$bin?=@src/ports/tang_nano_4k/build/firmware.elf

machine LoadPlatformDescription $repl

# Set CPU clock and performance to match 27MHz hardware for accurate SysTick timing
sysbus.cpu ClockFrequency 27000000
sysbus.cpu PerformanceInMips 27

showAnalyzer uart0

macro reset
"""
    sysbus LoadELF $bin
"""

runMacro $reset
