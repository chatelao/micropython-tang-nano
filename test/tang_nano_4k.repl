// tang_nano_4k.repl

nvic: IRQControllers.NVIC @ sysbus 0xE000E000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic

// Internal Flash (Code Flash) - 128KB
flash: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x20000

// Internal SRAM - 22KB
sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x5800

// CMSDK UART0 - Moved to correct hardware base address
// Routed via FPGA fabric to physical pins:
// TX -> FPGA Pin 18 (IOB13A)
// RX -> FPGA Pin 19 (IOB13B)
uart0: UART.CMSDK_APB_UART @ sysbus 0x40004000
    frequency: 27000000

// I2C Master - Mapped as memory for simulation
i2c0: Memory.MappedMemory @ sysbus 0x40002000
    size: 0x400

// SPI Master - Mapped as memory for simulation
spi0: Memory.MappedMemory @ sysbus 0x40002400
    size: 0x400

// External SPI NOR Flash - 4MB
// Mapped at 0x60000000 for simulation purposes
external_flash: Memory.MappedMemory @ sysbus 0x60000000
    size: 0x400000

// GPIO Bridge - 16-bit (ARM AHB GPIO / CMSDK)
gpio0: GPIOPort.ARM_AHB_GPIO @ sysbus 0x40010000
    0 -> nvic @ 16
    1 -> nvic @ 17
    2 -> nvic @ 18
    3 -> nvic @ 19
    4 -> nvic @ 20
    5 -> nvic @ 21
    6 -> nvic @ 22
    7 -> nvic @ 23
    8 -> nvic @ 24
    9 -> nvic @ 25
    10 -> nvic @ 26
    11 -> nvic @ 27
    12 -> nvic @ 28
    13 -> nvic @ 29
    14 -> nvic @ 30
    15 -> nvic @ 31

// ADC - 8-channel 12-bit (Mapped as memory for simulation)
adc0: Memory.MappedMemory @ sysbus 0x40002800
    size: 0x400

// Watchdog Timer (Mapped as memory for simulation)
wdt0: Memory.MappedMemory @ sysbus 0x40008000
    size: 0x1000

// RTC (Mapped as memory for simulation)
rtc0: Memory.MappedMemory @ sysbus 0x40006000
    size: 0x400

// FPGA DMA Controller (Mapped as memory for simulation)
// Base 0x40002C00 (APB2 Slot 9) - Must be 0x400 aligned
dma0: Memory.MappedMemory @ sysbus 0x40002C00
    size: 0x400

// FPGA RAM - AHB2 Master region
// Simulated PSRAM (8MB)
fpga_ram: Memory.MappedMemory @ sysbus 0xA0000000
    size: 0x800000
