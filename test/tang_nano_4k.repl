// tang_nano_4k.repl

nvic: IRQControllers.NVIC @ sysbus 0xE000E000

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m3"
    nvic: nvic

// Internal Flash (User Flash) - 32KB
flash: Memory.MappedMemory @ sysbus 0x00000000
    size: 0x8000

// Internal SRAM - 22KB
sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x5800

// CMSDK UART0 - Moved to correct hardware base address
uart0: UART.CMSDK_APB_UART @ sysbus 0x40004000
    frequency: 27000000

// APB2 Peripherals (I2C, SPI, ADC, etc.)
// Grouped into a single 4KB region to satisfy Renode's 0x400 (1KB) page alignment requirement.
apb2_peripherals: Memory.MappedMemory @ sysbus 0x40002000
    size: 0x1000

// External SPI NOR Flash - 4MB
// Mapped at 0x60000000 for simulation purposes
external_flash: Memory.MappedMemory @ sysbus 0x60000000
    size: 0x400000

// GPIO Bridge - 16-bit (ARM AHB GPIO / CMSDK)
gpio0: GPIOPort.ARM_AHB_GPIO @ sysbus 0x40010000
    0 -> nvic @ 16
    1 -> nvic @ 17
    2 -> nvic @ 18
    3 -> nvic @ 19
    4 -> nvic @ 20
    5 -> nvic @ 21
    6 -> nvic @ 22
    7 -> nvic @ 23
    8 -> nvic @ 24
    9 -> nvic @ 25
    10 -> nvic @ 26
    11 -> nvic @ 27
    12 -> nvic @ 28
    13 -> nvic @ 29
    14 -> nvic @ 30
    15 -> nvic @ 31

